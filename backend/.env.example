# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000

# ─── Database ─────────────────────────────────────────────────────────────────
# Leave blank to use ./contracts.db (local dev).
# On Render set to: /data/contracts.db
DB_PATH=

# ─── File Uploads ─────────────────────────────────────────────────────────────
# Leave blank to use ./uploads (local dev).
# On Render set to: /data/uploads
UPLOAD_DIR=

# ─── Frontend URL ─────────────────────────────────────────────────────────────
# Used in password-reset emails and Stripe redirect URLs.
# Local dev:  http://localhost:3000
# Production: https://vendorshield.onrender.com
FRONTEND_URL=http://localhost:3000

# ─── Google Gemini AI ─────────────────────────────────────────────────────────
# Free key: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
# Gmail: use an App Password (not your account password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@vendorshield.com

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=
# Run: stripe listen --forward-to localhost:5000/api/stripe/webhook
# Production: add webhook in Stripe dashboard → https://your-api.onrender.com/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=
# Dashboard → Products (create 3 recurring INR products, copy price_... IDs)
STRIPE_BASIC_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=
